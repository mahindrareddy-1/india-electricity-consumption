# Database configuration
# Not read by app.py (it reads web_app/data/electricity_consumption.csv
# directly), kept here only as a reference for reconnecting in MySQL
# Workbench / Tableau.
DB_HOST=localhost
DB_USER=app_user
DB_PASSWORD=your_mysql_password_here
DB_NAME=electricity_db

# Tableau Configuration
# Local dev: copy this file to .env and fill in the real value.
# Production (Render): do NOT put this in a file at all -- set it as an
# environment variable in the Render dashboard instead (Settings ->
# Environment). Render injects it at runtime; it never touches git.
TABLEAU_EMBED_URL=https://public.tableau.com/views/India_Electricity_Consumption_Story/Story1
